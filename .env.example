# ==============================
# 每日 AI 情报自动化（示例）
# ==============================
# 日报来源输入文件（本地调试时可直接使用 temp/ai-daily-source-items.sample.json）
# AI_DAILY_SOURCE_FILE=./temp/ai-daily-source-items.sample.json
# 候选池输出文件
# AI_DAILY_CANDIDATES_FILE=./temp/ai-daily-candidates.json
# 最终文章 JSON 输出文件
# AI_DAILY_POST_JSON=./temp/ai-daily-post.json
# 最终文章 Markdown 输出文件
# AI_DAILY_POST_MD=./temp/ai-daily-post.md
# 近多少小时内的情报纳入候选池
# AI_DAILY_HOURS_WINDOW=24
# 候选池最多保留多少条
# AI_DAILY_MAX_CANDIDATES=12
# 可选：单独指定日报写作接口；不填时复用 AI_SUMMARY_API
# AI_DAILY_API=
# 可选：单独指定日报写作密钥；不填时复用 AI_SUMMARY_KEY
# AI_DAILY_KEY=
# 可选：指定日报模型名
# AI_DAILY_MODEL=gpt-5.4
# 日报目标 Notion 数据库 ID
# AI_DAILY_NOTION_DATABASE_ID=
# Dry Run 模式：设为 1 时仅打印 payload，不真正写入 Notion
# AI_DAILY_DRY_RUN=1
# 以下字段名默认已适配当前库结构，如需自定义可取消注释覆盖
# AI_DAILY_NOTION_TITLE_PROPERTY=title
# AI_DAILY_NOTION_TYPE_PROPERTY=type
# AI_DAILY_NOTION_STATUS_PROPERTY=status
# AI_DAILY_NOTION_DATE_PROPERTY=date
# AI_DAILY_NOTION_SLUG_PROPERTY=slug
# AI_DAILY_NOTION_SUMMARY_PROPERTY=summary
# AI_DAILY_NOTION_TAGS_PROPERTY=tags
# AI_DAILY_NOTION_CATEGORY_PROPERTY=category
# AI_DAILY_NOTION_ICON_PROPERTY=icon
# AI_DAILY_NOTION_PASSWORD_PROPERTY=password
# AI_DAILY_NOTION_AI_SUMMARY_PROPERTY=ai_summary
# 如果数据库字段选项值与你当前默认值不同，可在生成阶段自行覆盖对应产物字段
